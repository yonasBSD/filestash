@@ -169,2 +178,44 @@ export default async function(render, { acl$, getFilename, getDownloadUrl, mime

+    // feature: collaborative editing
+    effect(setup$.pipe(
+        rxjs.mergeMap((editor) => {
+            const path = encodeURIComponent(getCurrentPath());
+            const clientID = Math.random().toString(36).slice(2);
+
+            const pull$ = new rxjs.Observable((observer) => {
+                const es = new EventSource(forwardURLParams("api/codemirror/pull?path=" + path, ["share"]));
+                es.onmessage = (ev) => {
+                    for (const change of JSON.parse(ev.data)) {
+                        if (change.clientID === clientID) continue;
+                        editor.replaceRange(change.text, change.from, change.to, "remote");
+                    }
+                };
+                es.onerror = () => observer.error();
+                return () => es.close();
+            }).pipe(rxjs.retry({ delay: 2000 }));
+
+            const push$ = new rxjs.Observable((observer) => editor.on("change", (cm, change) => {
+                if (change.origin === "remote") return;
+                observer.next(change);
+            })).pipe(
+                rxjs.buffer(rxjs.interval(500)),
+                rxjs.filter((changes) => changes.length > 0),
+                rxjs.concatMap((changes) => ajax({
+                    url: forwardURLParams("api/codemirror/push?path=" + path, ["share"]),
+                    method: "POST",
+                    body: JSON.stringify({
+                        changes: changes.map(({ from, to, text, removed }) => ({
+                            from, to, text, removed,
+                            clientID,
+                        })),
+                    }),
+                    headers: { "Content-Type": "application/json" },
+                })),
+                rxjs.retry({ delay: 2000 }),
+            );
+
+            return rxjs.merge(pull$, push$);
+        }),
+    ));
+
